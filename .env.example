# stable-v2 environment configuration.
# Copy to `.env` (gitignored) and fill in. Real environment variables override
# these. All values have sensible LOCAL defaults in core/config.py, so a local
# dev machine needs nothing here.

# --- Database (v2) ------------------------------------------------------------
# Local default (Postgres.app): postgresql://jakob@localhost:5432/stable_v2
# In the cloud (Railway), point this at the Supabase pooler connection string:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# DATABASE_URL=postgresql://jakob@localhost:5432/stable_v2

# --- Supabase publish target (local writer → cloud replica) -------------------
# Only the local nightly `--publish` step uses this. Leave empty on the cloud
# host (the cloud app reads DATABASE_URL, it doesn't publish).
# SUPABASE_DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- Legacy v1 bridge (deprecated) --------------------------------------------
# Native ATG is the default. Set to 1 ONLY to fall back to the old v1 subprocess
# bridge (requires the v1 project at V1_PROJECT_ROOT and its `jakob` database).
# USE_V1_BRIDGE=0
# V1_PROJECT_ROOT=/Users/jakob/Dev/stable
# V1_DATABASE_NAME=jakob
# V1_DATABASE_HOST=/tmp
# V1_DATABASE_PORT=5432
# V1_DATABASE_USER=jakob

# --- Web ----------------------------------------------------------------------
# WEB_PORT=5002          # local; on Railway bind to $PORT (see Procfile)
